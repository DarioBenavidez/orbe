{
  "expo": {
    "name": "Orbe",
    "slug": "orbe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "orbe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#005247"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "package": "com.dariobenavidez.orbe"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/orbe-logo.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#005247",
          "dark": {
            "backgroundColor": "#005247"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f2dbe64b-1bad-4d42-ab93-b70ed7dfd011"
      }
    },
    "owner": "dariobenavidez",
    "updates": {
      "enabled": false
    }
  }
}
